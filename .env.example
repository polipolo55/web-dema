# Demà Band Website Environment Variables
# Copy this file to .env and set your values

# IMPORTANT: Change this password before deploying!
# Use a strong, unique password
ADMIN_PASSWORD=dema2025!
# Session cookie name for admin auth
# ADMIN_SESSION_COOKIE_NAME=dema_admin_session
# Session TTL in milliseconds (default 8h)
# ADMIN_SESSION_TTL_MS=28800000

# Runtime environment
# NODE_ENV=development

# Server settings
# PORT=3001
# JSON_BODY_LIMIT=1mb

# Proxy handling (set to 1 or true when running behind nginx/reverse proxy)
# TRUST_PROXY=1

# Database path (recommended to set explicitly in production)
# DATABASE_PATH=./data/band.db

# Rate limit settings
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100

# Additional security settings (reserved)
